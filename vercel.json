{
  "rewrites": [
    { "source": "/", "destination": "/index.html" },
    { "source": "/timbratura.html", "destination": "/timbratura.html" },
    { "source": "/admin.html", "destination": "/admin.html" },
    { "source": "/admin-jerago.html", "destination": "/admin-parrocchia.html" },
    { "source": "/admin-orago.html", "destination": "/admin-parrocchia.html" },
    { "source": "/admin-besnate.html", "destination": "/admin-parrocchia.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    },
    {
      "source": "/sw.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache" },
        { "key": "Content-Type", "value": "application/javascript" }
      ]
    },
    {
      "source": "/manifest.json",
      "headers": [
        { "key": "Content-Type", "value": "application/manifest+json" }
      ]
    }
  ]
}
